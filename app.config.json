{
    "window": {
        "title": "MeshScope 3D",
        "width": 1460,
        "height": 920,
        "minWidth": 980,
        "minHeight": 640,
        "frameless": false,
        "backgroundColor": "#eef2f6",
        "resizable": true,
        "alwaysOnTop": false
    },
    "dev": {
        "port": 3000,
        "command": "npx vite --port 3000",
        "waitForPort": true
    },
    "build": {
        "command": "npx vite build",
        "outDir": "dist"
    }
}
